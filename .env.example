DATABASE_URL=postgresql+psycopg2://bookstore:bookstore@localhost:5432/bookstore
REDIS_URL=redis://localhost:6379/0
# Local sem servidor: file:./mlruns | Com Docker: http://localhost:5000
MLFLOW_TRACKING_URI=file:./mlruns
JWT_SECRET=dev-secret-change-in-production
CONFIG_DIR=./config

# --- Opcional: API admin (header X-Admin-Token em rotas administrativas) ---
# ADMIN_TOKEN=

# --- Opcional: pesos do motor híbrido (padrão 0,50 / 0,35 / 0,15) ---
# REC_W_OWN=0.50
# REC_W_SIM=0.35
# REC_W_VEC=0.15
# Perfil mais assertivo (mais vizinhos + semântica; bom com embeddings)
# REC_W_OWN=0.30
# REC_W_SIM=0.45
# REC_W_VEC=0.25
# REC_CACHE_TTL=3600

# --- Opcional: modelo sentence-transformers (seed --embed, sync_book_embeddings, API) ---
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# --- Opcional: JSON de métricas offline expostas em /metrics após train.py ---
# TRAIN_METRICS_EXPORT_PATH=data/train_metrics_last.json

# --- train_scheduler (perfil hourly-train): segundos entre um treino e o próximo (MLflow + JSON de métricas) ---
# Produção / dia a dia: 1 h
# TRAIN_INTERVAL_SECONDS=3600
# Apresentação / demo (ex.: novo batch a cada 3 min): descomente e ajuste; depois recrie o container (ver README)
# TRAIN_INTERVAL_SECONDS=180

# --- Esqueleto ranker MLflow na API (1/true): tenta gateway primeiro; hoje sempre fallback no motor heurístico — ver README seção 1 ---
# USE_MLFLOW_ONLINE_RANKER=true
